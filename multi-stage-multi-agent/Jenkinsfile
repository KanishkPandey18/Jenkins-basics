pipeline {
  agent any

  stages {

    stage('Build Image') {
      steps {
        dir('multi-stage-multi-agent') {
          sh 'docker build -t my-app .'
        }
      }
    }

    stage('Login to JFrog') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'jfrog-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
          sh '''
          echo $PASS | docker login yourcompany.jfrog.io -u $USER --password-stdin
          '''
        }
      }
    }

    stage('Tag Image') {
      steps {
        sh 'docker tag my-app yourcompany.jfrog.io/docker-repo/my-app:latest'
      }
    }

    stage('Push to JFrog') {
      steps {
        sh 'docker push yourcompany.jfrog.io/docker-repo/my-app:latest'
      }
    }
  }
}
