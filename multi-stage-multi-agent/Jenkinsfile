pipeline {
    agent any

  environment {
    // Change 'nexus' to the Docker Gateway IP
    REGISTRY = "172.17.0.1:8082" 
    IMAGE    = "my-app"
    CRED_ID  = "nexus-deploy-creds"
}

    stages {
        stage('Build Image') {
            steps {
                // Navigating to your specific sub-directory
                dir('multi-stage-multi-agent') {
                    sh "docker build -t ${IMAGE} ."
                }
            }
        }

        stage('Login to Nexus') {
            steps {
                script {
                    // This pulls the username and password from Jenkins Credentials store
                    withCredentials([usernamePassword(
                        credentialsId: "${CREDENTIALS_ID}",
                        usernameVariable: 'USER',
                        passwordVariable: 'PASS'
                    )]) {
                        sh "echo ${PASS} | docker login ${REGISTRY} -u ${USER} --password-stdin"
                    }
                }
            }
        }

        stage('Tag and Push') {
            steps {
                sh "docker tag ${IMAGE} ${REGISTRY}/${IMAGE}:latest"
                sh "docker push ${REGISTRY}/${IMAGE}:latest"
            }
        }
    }

    post {
        always {
            // Good practice: Logout to keep the build agent clean
            sh "docker logout ${REGISTRY}"
        }
    }
}
