pipeline {
    agent any

    environment {
        // Use the Docker Gateway IP for the internal connection
        REGISTRY = "172.17.0.1:8082" 
        IMAGE    = "my-app"
        // Let's use a clear, consistent name here
        NEXUS_CRED_ID = "nexus-deploy-creds" 
    }

    stages {
        stage('Build Image') {
            steps {
                dir('multi-stage-multi-agent') {
                    sh "docker build -t ${IMAGE} ."
                }
            }
        }

        stage('Login to Nexus') {
            steps {
                script {
                    // This variable name MUST match the environment block above
                    withCredentials([usernamePassword(
                        credentialsId: "${NEXUS_CRED_ID}", 
                        usernameVariable: 'USER', 
                        passwordVariable: 'PASS'
                    )]) {
                        sh "echo ${PASS} | docker login ${REGISTRY} -u ${USER} --password-stdin"
                    }
                }
            }
        }

        stage('Tag and Push') {
            steps {
                sh "docker tag ${IMAGE} ${REGISTRY}/${IMAGE}:latest"
                sh "docker push ${REGISTRY}/${IMAGE}:latest"
            }
        }
    }

    post {
        always {
            sh "docker logout ${REGISTRY}"
        }
    }
}
